library(terra)
library(dplyr)  
library(tidyr)   # opcional

# 1. Diretórios (ajuste se necessário)
dir_base <- "G:/Drives compartilhados/Biodiversidade & Desenvolvimento Circular/5.Projetos Ativos/Curvelo   Estratégia SbN e Conectividade"
dir_lulc <- file.path(dir_base, "2 P1 - Diagnóstico/2 Dados/Dados abertos/LULC")
dir_sed  <- file.path(dir_base, "2 P1 - Diagnóstico/5. Resultados/Camadas GEO/DSE/Retenção de Sedimentos")

# 2. Ler raster de uso do solo (referência)
lulc_files <- list.files(dir_lulc, pattern = "mapbiomas.*\\.tif$", full.names = TRUE)
if (length(lulc_files) == 0) stop("Arquivo de uso do solo não encontrado!")
lulc <- rast(lulc_files[1])
cat("Raster LULC lido. Extensão:", as.character(ext(lulc)), "\n")
cat("Resolução LULC:", res(lulc), "\n")

# 3. Lista dos arquivos de sedimentos
arquivos_sed <- c(
  perda_solo        = file.path(dir_sed, "DSE_Curvelo_erosao.tif"),
  erosao_evitada    = file.path(dir_sed, "DSE_Curvelo_erosão_evitado.tif"),
  assoreamento      = file.path(dir_sed, "DSE_Curvelo_assoreamento_evitado.tif"),
  deposicao         = file.path(dir_sed, "DSE_Curvelo_deposicao_sedimentos.tif")
)

# 4. Função para alinhar cada raster ao LULC (projeção, extensão, resolução)
alinhar_ao_lulc <- function(caminho, ref) {
  cat("Processando:", basename(caminho), "\n")
  r <- rast(caminho)
  
  # a) Verificar/projetar CRS
  if (crs(r) != crs(ref)) {
    cat("  - Projetando CRS...\n")
    r <- project(r, crs(ref), method = "bilinear")
  }
  
  # b) Recortar para a extensão exata do ref (usando snap para evitar bordas)
  if (!(ext(r) == ext(ref))) {
    cat("  - Recortando para extensão do LULC...\n")
    r <- crop(r, ref, snap = "out")
  }
  
  # c) Reamostrar para a mesma resolução e origem do ref
  if (!all(res(r) == res(ref))) {
    cat("  - Reamostrando para resolução do LULC...\n")
    r <- resample(r, ref, method = "bilinear")
  }
  
  # d) Garantir que a extensão final seja exatamente a do ref (pode haver diferenças de 1 pixel)
  #    Usar extend() com fill=NA para forçar a mesma extensão
  if (!(ext(r) == ext(ref))) {
    cat("  - Ajustando extensão final com extend()...\n")
    r <- extend(r, ref, fill = NA)
  }
  
  # e) Atribuir o mesmo sistema de referência (por segurança)
  crs(r) <- crs(ref)
  
  return(r)
}

# 5. Alinhar cada raster de sedimento e guardar em uma lista
sed_list <- list()
for (nome in names(arquivos_sed)) {
  sed_list[[nome]] <- alinhar_ao_lulc(arquivos_sed[nome], lulc)
}

# 6. Empilhar os rasters alinhados
sed_stack <- rast(sed_list)
# Atribuir nomes descritivos
names(sed_stack) <- c("Perda_solo", "Erosao_evitada", "Assoreamento_evitado", "Deposicao_sedimentos")

cat("\nEmpilhamento concluído. Dimensões:", dim(sed_stack), "\n")
cat("Extensão final:", as.character(ext(sed_stack)), "\n")

# 7. Calcular médias zonais
medias_por_classe <- zonal(sed_stack, lulc, fun = "mean", na.rm = TRUE)
colnames(medias_por_classe)[1] <- "classe"

# 8. Exibir resultados
print("===== MÉDIAS POR CLASSE DE USO =====")
print(medias_por_classe)

# 9. (Opcional) Adicionar nomes das classes (MapBiomas Coleção 2.10 beta)
legenda <- data.frame(
  classe = c(1, 3, 4, 5, 6, 9, 11, 12, 13, 15, 19, 20, 21, 22, 23, 24, 25, 26, 27, 29, 30, 31, 32, 33),
  nome   = c("Floresta", "Formação Natural não Florestal", "Área Úmida", "Pastagem", "Agricultura",
             "Área Urbana", "Água", "Infraestrutura", "Solo Exposto", "Afloramento Rochoso",
             "Outros", "Mangue", "Marismas", "Apicum", "Salina", "Aquicultura", "Rio", "Lago",
             "Açude", "Floresta Plantada", "Campo Alagado", "Cana-de-açúcar", 
             "Mosaico de Agricultura e Pastagem", "Mosaico de Floresta e Pastagem")
)
medias_com_nomes <- left_join(medias_por_classe, legenda, by = "classe")
print("===== COM NOMES DAS CLASSES =====")
print(medias_com_nomes)

# 10. (Opcional) Formato longo
medias_long <- pivot_longer(medias_por_classe, cols = -classe, names_to = "Variavel", values_to = "Media")
print("===== FORMATO LONGO =====")
print(medias_long)

write.csv(medias_com_nomes, file = "medias_por_classe.csv", row.names = FALSE)
write.csv(medias_com_nomes, file = file.path(dir_base, "medias_por_classe.csv"), row.names = FALSE)
write.csv(medias_long, file = "medias_por_classe_long.csv", row.names = FALSE)

# Exportar tabela com nomes das classes (CSV)
write.csv(medias_com_nomes, 
          file = file.path(dir_base, "medias_por_classe.csv"), 
          row.names = FALSE)

# (Opcional) Exportar formato longo
write.csv(medias_long, 
          file = file.path(dir_base, "medias_por_classe_long.csv"), 
          row.names = FALSE)

