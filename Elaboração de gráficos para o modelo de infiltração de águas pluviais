uso_rast <- rast(uso_path)

message("Verificando arquivos de métricas...")
metricas_existentes <- list()
for (nome in names(metricas)) {
  caminho <- file.path(raster_metrics_dir, metricas[[nome]])
  if (file.exists(caminho)) {
    metricas_existentes[[nome]] <- metricas[[nome]]
  } else {
    warning(paste("Arquivo não encontrado:", caminho, "- Pulando", nome))
  }
}

